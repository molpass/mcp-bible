{
  "name": "mcp-bible",
  "version": "1.0.0",
  "description": "Bible helper MCP — multi-version lookup, original-language word study, keyword/semantic search, cross-references. stdio.",
  "type": "module",
  "bin": {
    "mcp-bible": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "fetch": "npm run build:scripts && node dist-scripts/fetch-sources.js",
    "build:db": "npm run build && npm run build:scripts && node dist-scripts/build-db.js",
    "build:embeddings": "npm run build && npm run build:scripts && node dist-scripts/build-embeddings.js",
    "start": "node dist/index.js",
    "example": "node examples/run-examples.mjs",
    "test": "node --test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hermes-agent",
    "claude",
    "bible",
    "korean",
    "telegram"
  ],
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-xml-parser": "^5.9.3",
    "typescript": "^5.5.0",
    "xlsx": "^0.18.5"
  }
}
